rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only signed-in users may read or write any data.
    // Tighten further later (e.g. per-user roles) if needed.
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }

    match /documents/{docId} {
      allow read, write: if request.auth != null;
    }

    match /meta/{metaId} {
      allow read, write: if request.auth != null;
    }

    match /changelog/{entryId} {
      allow read, write: if request.auth != null;
    }

    match /team/{memberId} {
      allow read, write: if request.auth != null;
    }

    match /messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    match /activity/{entryId} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /dmMessages/{messageId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantUids;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.threadId is string
        && request.resource.data.participantUids.size() == 2;
      allow update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
